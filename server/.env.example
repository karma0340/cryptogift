# CryptoGift Backend - Environment Variables

# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cryptogift

# URLs
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-backend-api.vercel.app

# NOWPayments API (Crypto Payment Gateway)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_here

# Reloadly API (Gift Card Supplier)
RELOADLY_CLIENT_ID=your_reloadly_client_id_here
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret_here
RELOADLY_SANDBOX=false

# Email Delivery (SMTP)
# Using Gmail? Create an "App Password" at myaccount.google.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
