# CryptoGift Backend — Environment Variables Template
# Copy this to .env and fill in your real values

PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/cryptogift

# NOWPayments (get from nowpayments.io dashboard)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret

# Reloadly (get from reloadly.com → Developers → API)
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret
RELOADLY_SANDBOX=false

# URLs (update with your deployed URLs)
FRONTEND_URL=https://cryptogift-murex.vercel.app
BACKEND_URL=https://cryptogift-jj7h.vercel.app

# Admin
ADMIN_PASSWORD=your_secure_admin_password
JWT_SECRET=your_random_jwt_secret_min_32_chars

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password_no_spaces
ADMIN_EMAIL=your_admin_notification_email@gmail.com
